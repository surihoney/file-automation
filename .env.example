# Copy this file to `.env` and fill in real values.
# Docker Compose auto-loads `.env` from this directory.
# Never commit `.env` — it is gitignored.

# ---- n8n ----
# Used by n8n to encrypt credentials at rest.
# Generate with: openssl rand -base64 32
# If you change this after n8n has stored credentials, they will stop decrypting.
N8N_ENCRYPTION_KEY=replace-me-with-output-of-openssl-rand-base64-32

# Basic-auth protecting the n8n UI at http://localhost:5678
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me
